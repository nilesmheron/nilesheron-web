{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/sandbox/personal-ai-os", "destination": "/onebite", "permanent": true },
    { "source": "/sandbox/personal-ai-os/report", "destination": "/onebite/report", "permanent": true }
  ],
  "rewrites": [
    { "source": "/templates/onboarding", "destination": "/templates/onboarding.html" },
    { "source": "/templates/task-management", "destination": "/templates/task-management.html" },
    { "source": "/templates/profile-versioning", "destination": "/templates/profile-versioning.html" },
    { "source": "/templates/cross-platform-packager", "destination": "/templates/cross-platform-packager.html" },
    { "source": "/mothership/charter-roadmap-gannt", "destination": "/mothership/charter-roadmap-gannt.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://niles-task-dashboard.vercel.app https://tasks.nilesheron.com http://localhost http://localhost:3000 http://localhost:3001"
        }
      ]
    }
  ]
}
